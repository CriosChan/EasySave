<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EasySave.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="Views/Styles/ButtonStyles.axaml" />
        <StyleInclude Source="Views/Styles/BorderStyles.axaml" />
        <StyleInclude Source="Views/Styles/TextStyles.axaml" />
        <StyleInclude Source="Views/Styles/ControlStyles.axaml" />
        <StyleInclude Source="Views/Styles/MenuStyles.axaml"/>
        <StyleInclude Source="Views/Styles/ListBoxStyles.axaml"/>
        <StyleInclude Source="Views/Styles/InputStyles.axaml"/>
    </Application.Styles>
    <Application.Resources>
        <!-- Primary Colors -->
        <SolidColorBrush x:Key="PrimaryBackground">#222831</SolidColorBrush>
        <SolidColorBrush x:Key="SecondaryBackground">#10FFFFFF</SolidColorBrush>

        <!-- Border Colors -->
        <SolidColorBrush x:Key="BorderLine">#22000000</SolidColorBrush>

        <!-- Button Colors -->
        <SolidColorBrush x:Key="ButtonSelected">#44FFFFFF</SolidColorBrush>

        <!-- Component Background Colors -->
        <SolidColorBrush x:Key="JobItemBackground">#10000000</SolidColorBrush>
        <SolidColorBrush x:Key="StatusBackground">#18003D7A</SolidColorBrush>
        <SolidColorBrush x:Key="StatusBorder">#33003D7A</SolidColorBrush>

        <!-- Progress Bar Colors -->
        <SolidColorBrush x:Key="ProgressSuccess">#4CAF50</SolidColorBrush>
        
        <!-- Menu Settings And Dropdowns Colors --> <!-- Those meaningless keys name is required because of a bug in Avalonia-->
        <SolidColorBrush x:Key="MenuFlyoutPresenterBackground">#222831</SolidColorBrush>
        <SolidColorBrush x:Key="ListBoxPresenterBackground">#222831</SolidColorBrush>
        <SolidColorBrush x:Key="ComboBoxDropDownBackground">#222831</SolidColorBrush>
        <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush">#22000000</SolidColorBrush>
        <SolidColorBrush x:Key="ComboBoxDropDownGlyphForeground">#F8F8F8</SolidColorBrush>
    </Application.Resources>
</Application>