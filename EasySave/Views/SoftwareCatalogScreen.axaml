<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:tlumach="clr-namespace:Tlumach.Avalonia;assembly=Tlumach.Avalonia"
             xmlns:translations="using:EasySave.Translation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="EasySave.Views.SoftwareCatalogScreen"
             xmlns:vm="using:EasySave.ViewModels"
             x:DataType="vm:MainWindowViewModel">
    <Grid
        IsVisible="{Binding IsSoftwareCatalogScreen}"
        RowDefinitions="Auto,Auto,*,Auto"
        RowSpacing="12">
        <Border Grid.Row="0"
                Classes="main-section">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12">
                <Button Grid.Column="0"
                        Content="{tlumach:Translate {x:Static translations:UiText.GuiNavigationBack}}"
                        Command="{Binding BackFromSoftwareCatalogCommand}" />
                <TextBlock Grid.Column="1"
                           Text="{tlumach:Translate {x:Static translations:UiText.GuiBusinessSoftwareCatalogTitle}}"
                           Classes="section-title"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                <Button Grid.Column="2"
                        Content="{tlumach:Translate {x:Static translations:UiText.GuiBusinessSoftwareButtonViewAdded}}"
                        Command="{Binding OpenAddedBusinessSoftwareCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Classes="main-section">
            <StackPanel Spacing="6">
                <TextBlock Text="{tlumach:Translate {x:Static translations:UiText.GuiBusinessSoftwareSearchLabel}}" />
                <TextBox Text="{Binding BusinessSoftware.BusinessSoftwareSearchText}"
                         Watermark="{tlumach:Translate {x:Static translations:UiText.GuiBusinessSoftwareSearchPlaceholder}}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Classes="main-section">
            <ListBox ItemsSource="{Binding BusinessSoftware.FilteredBusinessSoftware}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SelectableBusinessSoftwareItemViewModel">
                        <Border Classes="software-item">
                            <CheckBox IsChecked="{Binding IsSelected}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ProcessName}"
                                               Opacity="0.75" />
                                </StackPanel>
                            </CheckBox>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="3"
                Classes="main-section">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <Button
                    Content="{tlumach:Translate {x:Static translations:UiText.GuiBusinessSoftwareButtonAddSelected}}"
                    Command="{Binding BusinessSoftware.AddSelectedBusinessSoftwareCommand}"
                    IsVisible="{Binding BusinessSoftware.CanAddSelectedBusinessSoftware}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>