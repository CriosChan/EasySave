<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:tlumach="clr-namespace:Tlumach.Avalonia;assembly=Tlumach.Avalonia"
             xmlns:translations="using:EasySave.Translation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="EasySave.Views.SettingsScreen"
             xmlns:vm="using:EasySave.ViewModels"
             x:DataType="vm:MainWindowViewModel">
    <Grid
        IsVisible="{Binding IsSettingsScreen}"
        RowDefinitions="Auto,*"
        RowSpacing="12">
        <Border Grid.Row="0"
                Padding="12"
                CornerRadius="8"
                Background="{DynamicResource SecondaryBackground}"
                BorderBrush="{DynamicResource BorderLine}"
                BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12">
                <Button Grid.Column="0"
                        Content="{tlumach:Translate {x:Static translations:UiText.GuiNavigationBack}}"
                        Command="{Binding BackFromSettingsCommand}" />
                <TextBlock Grid.Column="1"
                           Text="{tlumach:Translate {x:Static translations:UiText.GuiSettingsScreenTitle}}"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="12"
                CornerRadius="8"
                Background="{DynamicResource SecondaryBackground}"
                BorderBrush="{DynamicResource BorderLine}"
                BorderThickness="1">
            <StackPanel Spacing="12">
                <Border Classes="main-section">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{tlumach:Translate {x:Static translations:UiText.GuiSettingsSectionLanguage}}"
                                   Classes="section-title" />
                        <WrapPanel>
                            <Button Content="{tlumach:Translate {x:Static translations:UiText.GuiButtonFrench}}"
                                    Command="{Binding Settings.SetFrenchLanguageCommand}"
                                    
                                    Margin="0,0,8,0" />
                            <Button Content="{tlumach:Translate {x:Static translations:UiText.GuiButtonEnglish}}"
                                    Command="{Binding Settings.SetEnglishLanguageCommand}"
                                     />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Classes="main-section">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{tlumach:Translate {x:Static translations:UiText.GuiSettingsSectionLogType}}"
                                   Classes="section-title" />
                        <WrapPanel>
                            <Button Content="{tlumach:Translate {x:Static translations:UiText.GuiButtonJson}}"
                                    Command="{Binding Settings.SetJsonLogTypeCommand}"
                                    
                                    Margin="0,0,8,0" />
                            <Button Content="{tlumach:Translate {x:Static translations:UiText.GuiButtonXml}}"
                                    Command="{Binding Settings.SetXmlLogTypeCommand}"
                                     />
                        </WrapPanel>
                    </StackPanel>
                </Border>
                
                <Border Classes="main-section">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{tlumach:Translate {x:Static translations:UiText.GuiSettingsCryptoSoftKey}}"
                                   Classes="section-title" />
                        <StackPanel Orientation="Vertical">
                            <TextBox Text="{Binding Settings.CryptoSoftKey}" HorizontalContentAlignment="Stretch"></TextBox>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <Grid ColumnDefinitions="*,16,*">
                    <!-- Left: extensions to crypt -->
                    <Border Grid.Column="0" Classes="main-section">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{tlumach:Translate {x:Static translations:UiText.GuiSettingsExtensionToCrypt}}"
                                       Classes="section-title" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding Settings.NewExtensionContent, Mode=TwoWay}"
                                         HorizontalContentAlignment="Stretch" />
                                <Button Content="{tlumach:Translate {x:Static translations:UiText.GuiAddExtension}}"
                                        Command="{Binding Settings.AddExtensionToCryptoSoftCommand}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Settings.CryptoSoftExtensions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False">
                                        <Button ToolTip.Tip="{tlumach:Translate {x:Static translations:UiText.GuiTooltipDeleteExtension}}"
                                                Content="{Binding}"
                                                Command="{Binding $parent[UserControl].DataContext.Settings.RemoveExtensionCommand}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Right: priority extensions -->
                    <Border Grid.Column="2" Classes="main-section">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{tlumach:Translate {x:Static translations:UiText.GuiSettingsPriorityExtensions}}"
                                       Classes="section-title" />
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding Settings.NewPriorityExtensionContent, Mode=TwoWay}"
                                         HorizontalContentAlignment="Stretch" />
                                <Button Content="{tlumach:Translate {x:Static translations:UiText.GuiAddPriorityExtension}}"
                                        Command="{Binding Settings.AddPriorityExtensionCommand}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Settings.PriorityExtensions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False">
                                        <Button ToolTip.Tip="{tlumach:Translate {x:Static translations:UiText.GuiTooltipDeletePriorityExtension}}"
                                                Content="{Binding}"
                                                Command="{Binding $parent[UserControl].DataContext.Settings.RemovePriorityExtensionCommand}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
