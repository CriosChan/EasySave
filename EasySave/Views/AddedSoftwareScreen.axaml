<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:tlumach="clr-namespace:Tlumach.Avalonia;assembly=Tlumach.Avalonia"
             xmlns:translations="using:EasySave.Translation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="EasySave.Views.AddedSoftwareScreen"
             xmlns:vm="using:EasySave.ViewModels"
             x:DataType="vm:MainWindowViewModel">
    <Grid
        IsVisible="{Binding IsAddedSoftwareScreen}"
        RowDefinitions="Auto,*,Auto"
        RowSpacing="12">
        <Border Grid.Row="0"
                Classes="main-section">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12">
                <Button Grid.Column="0"
                        Content="{tlumach:Translate {x:Static translations:UiText.GuiNavigationBack}}"
                        Command="{Binding BackFromAddedSoftwareCommand}" />
                <TextBlock Grid.Column="1"
                           Text="{tlumach:Translate {x:Static translations:UiText.GuiBusinessSoftwareAddedTitle}}"
                           Classes="section-title"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Classes="main-section">
            <ListBox ItemsSource="{Binding BusinessSoftware.AddedBusinessSoftware}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SelectableBusinessSoftwareItemViewModel">
                        <Border Classes="software-item">
                            <CheckBox IsChecked="{Binding IsSelected}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ProcessName}"
                                               Opacity="0.75" />
                                </StackPanel>
                            </CheckBox>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="2"
                Classes="main-section">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <Button Content="{tlumach:Translate {x:Static translations:UiText.GuiBusinessSoftwareButtonRemoveSelected}}"
                        Command="{Binding BusinessSoftware.RemoveSelectedAddedBusinessSoftwareCommand}"
                        IsVisible="{Binding BusinessSoftware.CanRemoveAddedBusinessSoftware}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
