<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="50">
            <StackPanel>
                <TextBox></TextBox>
                <ComboBox ItemsSource="ABC">
                </ComboBox>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
        <Setter Property="Foreground" Value="#F8F8F8"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderLine}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="6"/>
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
        <Setter Property="Foreground" Value="#F8F8F8"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderLine}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="6"/>
    </Style>
    <Style Selector="ComboBox:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ButtonSelected}"/>
        <Setter Property="Foreground" Value="#F8F8F8"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderLine}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="6"/>
    </Style>

    <!-- Dropdown items -->
    <Style Selector="ComboBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#F8F8F8"/>
        <Setter Property="Padding" Value="6"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ButtonSelected}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ButtonSelected}"/>
    </Style>
</Styles>
