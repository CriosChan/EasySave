<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="MenuItem">
        <Setter Property="Foreground" Value="#F8F8F8"/>
        <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
    </Style>
    <Style Selector="MenuItem:pointerover /template/ ContentPresenter">
        <Setter Property="Foreground" Value="#F8F8F8"/>
    </Style>
    <Style Selector="MenuItem:selected /template/ ContentPresenter">
        <Setter Property="Foreground" Value="#F8F8F8"/>
    </Style>
    
</Styles>
