<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="MenuItem">
        <Setter Property="Foreground" Value="#F8F8F8"/>
        <Setter Property="Background" Value="{DynamicResource SecondaryBackground}"/>
    </Style>
    <Style Selector="MenuItem:pointerover /template/ ContentPresenter">
        <Setter Property="Foreground" Value="#F8F8F8"/>
    </Style>
    <Style Selector="MenuItem:selected /template/ ContentPresenter">
        <Setter Property="Foreground" Value="#F8F8F8"/>
    </Style>

    <!-- Remove default top-level highlight rectangle for the menu icon button -->
    <Style Selector="MenuItem.menu-icon-item">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="MenuItem.menu-icon-item /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="MenuItem.menu-icon-item:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="MenuItem.menu-icon-item:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

</Styles>
