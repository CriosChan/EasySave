@startuml
title BackupTransferOrchestrator - detailed workflow (current app)

skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 100

actor "BackupExecutionEngine / BackupJob" as Caller
participant BackupTransferOrchestrator as Orchestrator
participant BackupJobController as Controller
participant BackupProgressTracker as Progress
participant CryptoSoftConfiguration as CryptoCfg
participant ApplicationConfiguration as Config
participant StateFileSingleton as StateFile
participant StateLogger
participant GlobalBusinessSoftwarePauseCoordinator as BizPause
participant BusinessSoftwareMonitor as BizMonitor
participant PathService as Paths
participant BackupFolder
participant TypeSelectorHelper as SelectorHelper
participant IBackupTypeSelector as Selector
participant FilePartitioner
participant GlobalPriorityArbitrator as Priority
participant GlobalLargeFileTransferLimiter as LargeLimiter
participant IFile as File
participant "ConfigurableLogWriter<LogEntry>" as Logger

Caller -> Orchestrator: Execute()
activate Orchestrator

Orchestrator -> Controller: WasStoppedByBusinessSoftware = false
Orchestrator -> Controller: NotifyBusinessSoftwarePause(false)
Orchestrator -> Controller: ResetStopped()
Orchestrator -> Progress: SetCurrentProgress(0)

Orchestrator -> CryptoCfg: Load().Save()
Orchestrator -> Config: Load()
Orchestrator -> StateFile: Initialize(LogPath)
Orchestrator -> StateFile: GetOrCreate(jobId, jobName)
StateFile --> Orchestrator: state
Orchestrator -> BizPause: RegisterJob(jobId, jobName, BizMonitor)
BizPause --> Orchestrator: registration scope

Orchestrator -> Paths: IsDirectoryAccessible(sourceDirectory)
Orchestrator -> Paths: IsDirectoryAccessible(targetDirectory)
alt source or target inaccessible
  Orchestrator -> StateLogger: SetStateFailed(state)
  Orchestrator -> Controller: Stop()
  note right
    registration scope is disposed automatically
    when Execute() returns
  end note
  Orchestrator --> Caller: return
  deactivate Orchestrator
else directories are accessible
  Orchestrator -> BackupFolder: MirrorFolder()
  Orchestrator -> SelectorHelper: GetSelector(type, source, target, backupName)
  SelectorHelper --> Orchestrator: selector
  Orchestrator -> Selector: GetFilesToBackup()
  Selector --> Orchestrator: files (NormalFile/CryptedFile)

  Orchestrator -> Progress: SetFilesCount(files.Count)
  Orchestrator -> Config: Load()
  Orchestrator -> FilePartitioner: Partition(files, PriorityExtensions)
  FilePartitioner --> Orchestrator: priorityQueue, standardQueue

  opt PriorityArbitrator configured
    Orchestrator -> Priority: Initialize({ jobId: priorityQueue.Count })
  end

  Orchestrator -> StateLogger: SetStateActive(state, filesCount, totalSize)
  Orchestrator -> StateFile: UpdateState(remaining priority/standard counts)

  loop priority queue then standard queue
    loop while queue has files
      Orchestrator -> BizPause: WaitWhileBusinessSoftwareRuns(jobId, state, blockedFile, shouldStop, notifyPause)
      alt stop requested
        break
      end

      alt standard file and global priority still pending
        loop until allowed
          Orchestrator -> Priority: CanProcessStandardFile(jobId)
          alt blocked
            Orchestrator -> StateLogger: SetStatePausedPriority(state)
            Orchestrator -> Controller: WaitIfPaused(100ms)
          end
        end
        Orchestrator -> StateLogger: SetStateActive(state, filesCount, totalSize)
      end

      Orchestrator -> File: GetSize()
      alt current queue is priority
        Orchestrator -> Priority: UpdateGlobalPriorityCount(jobId, queue.Count)
      end
      Orchestrator -> StateFile: UpdateState(remaining queue counts)

      Orchestrator -> LargeLimiter: RequiresExclusiveSlot(fileSizeBytes)
      alt large-file exclusive slot required
        loop until slot acquired
          Orchestrator -> LargeLimiter: TryAcquireExclusiveSlot(100ms)
          alt slot unavailable
            Orchestrator -> StateLogger: SetStateWaitingLargeFile(state, file)
            Orchestrator -> Controller: WaitIfPaused(100ms)
          end
        end
        opt waited for slot
          Orchestrator -> Logger: Log("Waited X ms for large-file transfer slot")
        end
      end

      Orchestrator -> StateLogger: SetStateStartTransfer(state, file, transferType)
      Orchestrator -> File: CopyAsync() (task)
      alt copy throws
        Orchestrator -> Orchestrator: hadError = true
      end
      opt large slot acquired
        Orchestrator -> LargeLimiter: ReleaseExclusiveSlot()
      end
      Orchestrator -> Progress: SetCurrentProgress(percentage)
      Orchestrator -> StateLogger: SetStateEndTransfer(...)
    end
  end

  Orchestrator -> Orchestrator: Task.WhenAll(fileTasks)
  opt PriorityArbitrator configured
    Orchestrator -> Priority: OnJobCompleted(jobId)
  end

  Orchestrator -> StateLogger: SetStateEnd(state, hadError, WasStopped)
  alt not stopped
    Orchestrator -> Progress: SetCurrentProgress(100)
  end

  note right
    registration scope is disposed automatically
    when Execute() returns
  end note
  Orchestrator --> Caller: EndEvent
  deactivate Orchestrator
end

@enduml
